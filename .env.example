# Twitch API Credentials
# Get these from: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# YouTube API Credentials
# Get these from: https://console.cloud.google.com/
# You'll need to download the client_secret.json and place it in the config folder
# The app will generate a token.json after first authentication

# Application Settings
CLIPS_COUNT=10
CLIPS_PERIOD=day
GAME_NAME=Just Chatting
LANGUAGE=en
CRON_SCHEDULE=0 9 * * *

# Video Settings (for YouTube Shorts)
VIDEO_TAGS=twitch,clips,shorts,gaming,highlights
VIDEO_CATEGORY_ID=20
VIDEO_PRIVACY=public
